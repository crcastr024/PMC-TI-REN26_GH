# GH1.9 — .gitignore PMC-TI-REN26

# Backups y versiones
*.backup
*_backup.*
pre_RC*.html
pre_GH*.html

# Archivos temporales
*.tmp
*.temp
*.log
*.bak

# Sistema operativo
.DS_Store
Thumbs.db
desktop.ini

# Editores
.vscode/
.idea/
*.swp
*~

# Test harness (no necesario para producción)
test_*.js
test_reports/

# Documentación técnica interna
*_ARCH/
*_REPORTS/
F7_ARCH/
MVP_REPORTS/

# Node modules (si se usan herramientas de desarrollo)
node_modules/
package-lock.json

# Excel y datos sensibles (NUNCA en el repositorio)
*.xlsx
*.xls

# Archivos de entorno
.env
.env.local
.env.*.local
